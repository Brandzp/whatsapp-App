# ── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Public base URL of this backend (used to build trackable short links)
PUBLIC_BASE_URL=http://localhost:4000
# Comma separated list of allowed admin-app origins
CORS_ORIGIN=http://localhost:5173

# ── Database (PostgreSQL / Supabase) ──
# Supabase → Project Settings → Database → Connection string → URI.
# Use the "Connection pooling" (pgBouncer, port 6543) URI for the app and add
# ?pgbouncer=true&connection_limit=1 so Prisma plays nice with the pooler.
# Run schema migrations against the direct connection (port 5432) instead.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ── Supabase Storage (for question voice notes) ──
# When both are set, uploaded audio is stored in a public Supabase bucket
# (survives Render redeploys). If left empty, uploads fall back to local disk.
# SUPABASE_URL → Project Settings → API → Project URL.
# SUPABASE_SERVICE_ROLE_KEY → Project Settings → API → service_role secret (server-only!).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=voice-notes

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── OpenAI (leave empty to use the built-in rule-based fallback) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Legal pages (served at /privacy and /terms — used for the Meta app token) ──
LEGAL_APP_NAME=WhatsApp Business AI Agent
LEGAL_COMPANY_NAME=Your Company
LEGAL_CONTACT_EMAIL=support@example.com
LEGAL_WEBSITE_URL=
LEGAL_EFFECTIVE_DATE=2026-06-09

# ── WhatsApp Cloud API (leave empty to use the local simulator) ──
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=my-verify-token
WHATSAPP_API_VERSION=v21.0
# Delay (ms) before sending a question's voice note when it also has an image,
# so the image (fetched by URL) arrives first. Default 1000. Lower = shorter wait.
MEDIA_SEND_DELAY_MS=1000
